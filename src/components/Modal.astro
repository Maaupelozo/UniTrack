---
const { id = "quick-modal", title = "Nueva actividad" } = Astro.props;
---

<dialog class="modal" id={id}>
  <form method="dialog" class="modal__surface">
    <header>
      <div>
        <span class="eyebrow">Registro rapido</span>
        <h2>{title}</h2>
      </div>
      <button class="icon-button" value="cancel" aria-label="Cerrar">
        <span class="icon icon--close" aria-hidden="true"></span>
      </button>
    </header>
    <div class="form-grid">
      <label>
        Materia
        <select>
          <option>Selecciona una materia</option>
        </select>
      </label>
      <label>
        Titulo
        <input type="text" value="Nueva entrega" />
      </label>
      <label>
        Fecha
        <input type="date" value="2026-06-18" />
      </label>
      <label>
        Prioridad
        <select>
          <option>Alta</option>
          <option>Media</option>
          <option>Baja</option>
        </select>
      </label>
    </div>
    <footer>
      <button class="button button--ghost" value="cancel">Cancelar</button>
      <button class="button" value="default">Guardar</button>
    </footer>
  </form>
</dialog>
