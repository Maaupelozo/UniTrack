---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/Card.astro";
---

<MainLayout
  title="Panel - UniTrack"
  pageTitle="Tu semana academica"
  subtitle="El tablero se completa solo con los datos que cargues con tu usuario."
>
  <section class="dashboard-grid">
    <Card class="hero-card">
      <div class="hero-card__copy">
        <span class="eyebrow">Panel personal</span>
        <h2 id="dashboard-title">Empeza cargando tus materias reales.</h2>
        <p>
          UniTrack no va a inventar materias ni pendientes. Cuando crees tus datos,
          este panel va a mostrar tu agenda academica real.
        </p>
        <div class="hero-card__actions">
          <a class="button" href="/materias">Agregar materia</a>
          <button class="button button--ghost" id="btn-agregar-pendiente">Agregar pendiente</button>
        </div>
      </div>
      <div class="focus-meter">
        <span>Estado</span>
        <strong id="dashboard-state">Sin datos</strong>
        <p id="dashboard-state-copy">Inicia sesion y carga tu primera materia.</p>
      </div>
    </Card>

    <div class="metric-row">
      <Card eyebrow="Materias">
        <h2 id="metric-materias-title">0</h2>
        <p id="metric-materias">sin materias cargadas</p>
      </Card>
      <Card eyebrow="Parciales">
        <h2 id="metric-parciales-title">0</h2>
        <p id="metric-parciales">sin evaluaciones cargadas</p>
      </Card>
      <Card eyebrow="Agenda">
        <h2 id="metric-agenda-title">0</h2>
        <p id="metric-agenda">sin eventos cargados</p>
      </Card>
    </div>

    <Card title="Materias en movimiento" class="span-2">
      <div class="subject-list" id="dashboard-materias">
        <article class="empty-panel">
          <strong>No hay materias todavia</strong>
          <span>Las materias que crees con tu usuario van a aparecer aca.</span>
        </article>
      </div>
    </Card>

    <Card title="TPs cercanos">
      <ul class="task-list" id="dashboard-tareas">
        <li>
          <span>
            <strong>No hay pendientes</strong>
            <small>Cuando cargues trabajos practicos, se mostraran aca.</small>
          </span>
        </li>
      </ul>
    </Card>

    <Card title="Linea de parciales" class="span-3">
      <div class="timeline" id="dashboard-agenda">
        <article class="empty-panel">
          <strong>No hay parciales ni eventos</strong>
          <span>Tu agenda se va a completar con datos reales de Supabase.</span>
        </article>
      </div>
    </Card>
  </section>

  <!-- Modal para agregar pendiente -->
  <div id="pendiente-modal" class="modal-overlay">
    <div class="modal-dialog">
      <div class="modal-header">
        <h2>Agregar pendiente</h2>
        <button class="modal-close" aria-label="Cerrar">&times;</button>
      </div>
      <form id="pendiente-form" class="modal-body">
        <label>
          Tipo
          <select id="pendiente-tipo" required>
            <option value="">Selecciona un tipo</option>
            <option value="tp">Trabajo Practico (TP)</option>
            <option value="parcial">Parcial</option>
          </select>
        </label>
        <label>
          Materia
          <select id="pendiente-materia" required>
            <option value="">Selecciona una materia</option>
          </select>
        </label>
        <label>
          Titulo/Descripcion
          <input id="pendiente-titulo" type="text" placeholder="Ej: Entrega del proyecto final" required />
        </label>
        <label>
          Fecha de entrega
          <input id="pendiente-fecha" type="date" required />
        </label>
        <div class="modal-actions">
          <button type="button" class="button button--ghost" id="pendiente-cancel">Cancelar</button>
          <button type="submit" class="button">Guardar pendiente</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from "../services/supabase.js";
    import { getMateriasFromSupabase } from "../services/materias.js";
    import { getAgendaAcademica, createPendiente, deleteTrabajoPractico } from "../services/parciales.js";

    const materiasContainer = document.querySelector("#dashboard-materias");
    const tareasContainer = document.querySelector("#dashboard-tareas");
    const agendaContainer = document.querySelector("#dashboard-agenda");
    const metricMateriasTitle = document.querySelector("#metric-materias-title");
    const metricMaterias = document.querySelector("#metric-materias");
    const metricParcialesTitle = document.querySelector("#metric-parciales-title");
    const metricParciales = document.querySelector("#metric-parciales");
    const metricAgendaTitle = document.querySelector("#metric-agenda-title");
    const metricAgenda = document.querySelector("#metric-agenda");
    const title = document.querySelector("#dashboard-title");
    const state = document.querySelector("#dashboard-state");
    const stateCopy = document.querySelector("#dashboard-state-copy");

    // Modal de pendientes
    const pendienteModal = document.querySelector("#pendiente-modal");
    const pendienteForm = document.querySelector("#pendiente-form");
    const pendienteTipo = document.querySelector("#pendiente-tipo");
    const pendienteMateria = document.querySelector("#pendiente-materia");
    const pendienteTitulo = document.querySelector("#pendiente-titulo");
    const pendienteFecha = document.querySelector("#pendiente-fecha");
    const btnAgregarPendiente = document.querySelector("#btn-agregar-pendiente");
    const pendienteClose = pendienteModal.querySelector(".modal-close");
    const pendienteCancel = document.querySelector("#pendiente-cancel");

    let materiasData = [];

    function formatDate(value) {
      if (!value) return "Sin fecha";
      return new Intl.DateTimeFormat("es-PY", {
        day: "numeric",
        month: "short",
        hour: "2-digit",
        minute: "2-digit"
      }).format(new Date(value));
    }

    function redirectToLogin() {
      window.location.href = "/login";
    }

    function renderMaterias(items) {
      metricMateriasTitle.textContent = items.length;
      if (!items.length) {
        materiasContainer.innerHTML = `
          <article class="empty-panel">
            <strong>No hay materias todavia</strong>
            <span>Agrega tu primera materia desde la pagina Materias.</span>
          </article>
        `;
        metricMaterias.textContent = "sin materias cargadas";
        return;
      }

      metricMaterias.textContent = items.length === 1
        ? "Estás inscripto en 1 materia"
        : `Estás inscripto en ${items.length} materias`;
      materiasContainer.innerHTML = items.slice(0, 4).map((materia) => `
        <a class="subject-row" href="/materias" style="--accent: #2f7d6f">
          <span class="subject-row__dot"></span>
          <div>
            <strong>${materia.nombre}</strong>
            <small>${materia.estado} · ${materia.anio ? `${materia.anio} ano` : "sin ano"}</small>
          </div>
          <div class="db-pill">${materia.nota_final ?? "Sin nota"}</div>
        </a>
      `).join("");

      metricMaterias.textContent = `${items.length} materia(s) desde Supabase`;
      state.textContent = "En marcha";
      stateCopy.textContent = "Tu panel ya esta usando datos reales.";
    }

    function renderAgenda(items) {
      const trabajos = items.filter((item) => item.tipo === "tp");
      const evaluaciones = items.filter((item) => item.tipo === "parcial" || item.tipo === "final");

      tareasContainer.innerHTML = trabajos.length ? trabajos.slice(0, 5).map((item) => `
        <li class="task-item task-item--tp" data-task-id="${item.id}">
          <label>
            <input type="checkbox" ${item.estado === "entregado" || item.estado === "aprobado" ? "checked" : ""} />
            <span>
              <strong>${item.titulo}</strong>
              <small>${item.materia} · ${formatDate(item.fecha)}</small>
            </span>
          </label>
          <button type="button" class="button button--ghost button--small task-delete">Borrar</button>
        </li>
      `).join("") : `
        <li>
          <span>
            <strong>No hay pendientes</strong>
            <small>Los trabajos practicos cargados van a aparecer aca.</small>
          </span>
        </li>
      `;

      agendaContainer.innerHTML = evaluaciones.length ? evaluaciones.slice(0, 6).map((item) => `
        <article class="timeline__item">
          <time>${formatDate(item.fecha)}</time>
          <div>
            <span>${item.tipo}</span>
            <strong>${item.titulo}</strong>
            <p>${item.materia} · ${item.estado}</p>
          </div>
        </article>
      `).join("") : `
        <article class="empty-panel">
          <strong>No hay parciales ni eventos</strong>
          <span>Carga parciales, TPs o eventos para armar tu linea de tiempo.</span>
        </article>
      `;

      metricAgendaTitle.textContent = items.length;
      metricAgenda.textContent = items.length
        ? `${items.length} evento(s) en agenda`
        : "sin eventos cargados";
      metricParcialesTitle.textContent = evaluaciones.length;
      metricParciales.textContent = evaluaciones.length
        ? `${evaluaciones.length} evaluacion(es) cargada(s)`
        : "sin evaluaciones cargadas";
    }

    async function syncDashboard() {
      const { data: sessionData } = await supabase.auth.getSession();
      if (!sessionData.session) {
        redirectToLogin();
        return;
      }

      const [materias, agenda] = await Promise.all([
        getMateriasFromSupabase(),
        getAgendaAcademica()
      ]);

      materiasData = materias;
      title.textContent = materias.length ? "Tu semana academica" : "Empeza cargando tus materias reales.";
      renderMaterias(materias);
      renderAgenda(agenda);
    }

    function openPendienteModal() {
      pendienteMateria.innerHTML = `
        <option value="">Selecciona una materia</option>
        ${materiasData.map((m) => `<option value="${m.id}">${m.nombre}</option>`).join("")}
      `;
      pendienteModal.classList.add("is-open");
    }

    function closePendienteModal() {
      pendienteModal.classList.remove("is-open");
      pendienteForm.reset();
    }

    // Event listeners para modal
    if (btnAgregarPendiente) {
      btnAgregarPendiente.addEventListener("click", openPendienteModal);
    }
    if (pendienteClose) {
      pendienteClose.addEventListener("click", closePendienteModal);
    }
    if (pendienteCancel) {
      pendienteCancel.addEventListener("click", closePendienteModal);
    }
    if (pendienteModal) {
      pendienteModal.addEventListener("click", (e) => {
        if (e.target === pendienteModal) closePendienteModal();
      });
    }

    if (pendienteForm) {
      pendienteForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        try {
          await createPendiente({
            tipo: pendienteTipo.value,
            materia_id: pendienteMateria.value,
            titulo: pendienteTitulo.value,
            fecha: pendienteFecha.value
          });

          closePendienteModal();
          await syncDashboard();
        } catch (error) {
          console.error("Error al crear pendiente:", error);
          alert("Error: " + error.message);
        }
      });
    }

    tareasContainer.addEventListener("click", async (event) => {
      const button = event.target.closest(".task-delete");
      if (!button) return;

      const taskItem = button.closest(".task-item");
      if (!taskItem) return;

      const trabajoId = taskItem.dataset.taskId;
      if (!trabajoId) return;

      try {
        await deleteTrabajoPractico(trabajoId);
        await syncDashboard();
      } catch (error) {
        console.error("Error al borrar TP:", error);
        alert("No se pudo borrar el TP.");
      }
    });

    syncDashboard().catch((error) => {
      console.error("No se pudo sincronizar el dashboard", error);
    });

  </script>
</MainLayout>
